{
  "name": "yaml-ns/wpp-framework",
  "description": "Reusable WordPress plugin framework base.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "YamlNs\\WppFramework\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "YamlNs\\WppFramework\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1",
    "psr/log": "^3.0"
  },
  "bin": [
    "bin/wpp"
  ],
  "config": {
    "platform": {
      "php": "8.1.0"
    }
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.68 <3.95",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "check:composer": "composer validate --strict",
    "analyse": "phpstan analyse",
    "cs:check": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix",
    "test": "phpunit",
    "ci": [
      "@check:composer",
      "@cs:check",
      "@analyse",
      "@test"
    ],
    "dump": "composer dump-autoload"
  }
}
